# Affiliate links — set these to your affiliate tracking URLs.
# When set, they override the default direct links to retailer websites.
# Example: AFFILIATE_AH=https://tc.tradetracker.net/?c=12345&m=67890&a=111111&r=&u=https%3A%2F%2Fwww.ah.be%2Fbonus

AFFILIATE_AH=
AFFILIATE_LIDL=
AFFILIATE_DELHAIZE=
AFFILIATE_COLRUYT=
AFFILIATE_ALDI=
AFFILIATE_ACTION=

# Microsoft Clarity — behavior analytics (heatmaps, session recordings)
# Get your project ID from https://clarity.microsoft.com/
# Only loaded after user accepts cookies (GDPR compliant)
NEXT_PUBLIC_CLARITY_ID=

# Site identity (used by robots/sitemap + metadata)
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_REGION=
NEXT_PUBLIC_SITE_DOMAIN=
NEXT_PUBLIC_RETAIL_VERTICAL=
NEXT_PUBLIC_FACEBOOK_GROUP_URL=

# Admin area basic auth (set both to enable /admin)
ADMIN_USER=
ADMIN_PASS=

# AdSense / ads.txt
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_ADS_TXT=
NEXT_PUBLIC_ADSENSE_EXCLUDE_PATH_PREFIXES=

# Analytics (loaded only after cookie consent)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Event logging database (optional; without it events are silently skipped)
POSTGRES_URL=

# Vercel Analytics + Speed Insights are enabled automatically (no config needed)
# They are cookie-less and privacy-friendly — no consent required
